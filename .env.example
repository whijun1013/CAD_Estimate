# CORS configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API security credentials
# Set this to a non-empty string to enforce API protection across endpoints
API_KEY=your_secure_api_key_here

# File upload controls
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=52428800

# Estimating parameters
DEFAULT_VAT_RATE=0.10
SURCHARGE_RATE=0.30

# Database URI (SQLite locally, PostgreSQL for production)
DATABASE_URL=sqlite:///./construction_orders.db

# AI Analysis and VLM Provider configuration
# Options: stub | openai | anthropic | qwen_local
VISION_ANALYZER_PROVIDER=stub
# AI review can be kept local/free while vision is disabled, or set to openai for paid API review.
# Options: local | stub | disabled | openai
AI_REVIEW_PROVIDER=local
ALLOW_MOCK_PROVIDER=false

# OpenAI settings (required when VISION_ANALYZER_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Anthropic settings (required when VISION_ANALYZER_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Qwen local endpoint (required when VISION_ANALYZER_PROVIDER=qwen_local)
QWEN_LOCAL_ENDPOINT=http://localhost:11434/v1
